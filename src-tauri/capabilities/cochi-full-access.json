{
  "$schema": "../schemas/desktop-schema.json",
  "identifier": "cochi-full-access",
  "description": "Cochi Desktop full system access",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" }
      ]
    },
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-exists",
    "fs:allow-stat",
    "shell:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-open"
  ]
}
